{
  "cli": {
    "version": ">= 16.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "development-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_DOMAIN": "https://api.ocrecipes.com",
        "EXPO_PUBLIC_SENTRY_DSN": "https://bf62b005c5085c50b08ad690c613ded4@o4511605735489536.ingest.us.sentry.io/4511605740142592",
        "SENTRY_ORG": "ocrecipes-wx",
        "SENTRY_PROJECT": "ocrecipes-mobile"
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_DOMAIN": "https://api.ocrecipes.com",
        "EXPO_PUBLIC_SENTRY_DSN": "https://bf62b005c5085c50b08ad690c613ded4@o4511605735489536.ingest.us.sentry.io/4511605740142592",
        "SENTRY_ORG": "ocrecipes-wx",
        "SENTRY_PROJECT": "ocrecipes-mobile",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      },
      "channel": "production"
    }
  }
}
