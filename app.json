{
  "expo": {
    "name": "OCRecipes",
    "slug": "ocrecipes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ocrecipes",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.williamtower.ocrecipes",
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": [
          "HKQuantityTypeIdentifierBodyMass",
          "HKQuantityTypeIdentifierStepCount",
          "HKQuantityTypeIdentifierActiveEnergyBurned"
        ]
      },
      "infoPlist": {
        "NSCameraUsageDescription": "OCRecipes needs camera access to scan barcodes and nutrition labels.",
        "NSMicrophoneUsageDescription": "OCRecipes uses the microphone for voice food logging.",
        "NSHealthShareUsageDescription": "OCRecipes reads your health data to sync weight, steps, and workouts.",
        "NSHealthUpdateUsageDescription": "OCRecipes writes nutrition data to Apple Health."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#00C853",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ocrecipes.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#00C853",
          "dark": {
            "backgroundColor": "#121212"
          }
        }
      ],
      "expo-web-browser",
      "expo-iap",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "OCRecipes needs camera access to scan barcodes and nutrition labels.",
          "enableCodeScanner": true
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "OCRecipes uses the microphone for voice food logging.",
          "speechRecognitionPermission": "OCRecipes uses speech recognition for voice food logging."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
