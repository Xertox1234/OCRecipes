# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# Claude Code instructions (local only)
CLAUDE.md

# Superpowers brainstorm sessions (visual companion server)
.superpowers/

# dependencies (no trailing slash: also ignores a `node_modules` symlink,
# which worktrees use to share the main checkout's install)
node_modules

# Build output
server_dist/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# IDE
.vscode/

# macOS
.DS_Store
*.pem

# Environment and secrets - SECURITY CRITICAL
.env
.env.*
.env*.local
*.secret
*.secrets

# typescript
*.tsbuildinfo

app-example

# Native folders (ios/, android/) are COMMITTED so EAS cloud builds use the real
# customized projects (VisionCamera, MLKit patches, ios.buildReactNativeFromSource).
# Build artifacts inside them (Pods/, build/, .gradle/, .xcode.env.local) are
# excluded by ios/.gitignore and android/.gitignore.
# Do NOT run `expo prebuild --clean` — it clobbers these customizations.

# Attached assets (user uploads during development)
attached_assets/

# Orphan bundled recipe images (generated at runtime in uploads/recipe-images/)
assets/images/recipes/

# User-uploaded avatars (keep directory structure via .gitkeep)
uploads/avatars/*
!uploads/avatars/.gitkeep

# Generated recipe images (keep directory structure via .gitkeep)
uploads/recipe-images/*
!uploads/recipe-images/.gitkeep

# Logs
*.log
logs/
/tmp/

# Test coverage
coverage/

# Local planning docs
docs/brainstorms/
docs/cowork/
docs/plans/
.claude/worktrees/
.claude/scheduled_tasks.lock
.ui-design/

# AI-workflow history: kept locally, not synced to GitHub.
# (todos/ stays tracked on purpose — it feeds Copilot work assignment.)
docs/superpowers/
docs/audits/
docs/research/
docs/LEARNINGS.md

# Dev workaround: symlink for Metro entry resolution
/index.js

# Evaluation results (contain API responses, timestamped per run)
evals/results/
.worktrees/

# Python bytecode cache (from scripts/kimi-review.py)
__pycache__/

# Mutation testing (Stryker) — runtime outputs only; baselines live in docs/mutation-testing/
.stryker-tmp/
reports/mutation/

# Art-direction preview batch (dev-only eyeball output from preview:art-direction)
scratch/art-direction-preview/
