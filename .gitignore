# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# Superpowers brainstorm sessions (visual companion server)
.superpowers/

# dependencies
node_modules/

# Build output
server_dist/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# IDE
.vscode/

# macOS
.DS_Store
*.pem

# Environment and secrets - SECURITY CRITICAL
.env
.env.*
.env*.local
*.secret
*.secrets

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# Attached assets (user uploads during development)
attached_assets/

# Orphan bundled recipe images (generated at runtime in uploads/recipe-images/)
assets/images/recipes/

# User-uploaded avatars (keep directory structure via .gitkeep)
uploads/avatars/*
!uploads/avatars/.gitkeep

# Generated recipe images (keep directory structure via .gitkeep)
uploads/recipe-images/*
!uploads/recipe-images/.gitkeep

# Logs
*.log
logs/
/tmp/

# Test coverage
coverage/

# Local planning docs
docs/brainstorms/
docs/plans/
todos/
.claude/worktrees/
.ui-design/

# Dev workaround: symlink for Metro entry resolution
/index.js

# Evaluation results (contain API responses, timestamped per run)
evals/results/
.worktrees/
