{
  "enabledPlugins": {},
  "permissions": {
    "allow": [
      "Bash(npx vitest run *)",
      "Bash(npx eslint *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 600,
            "statusMessage": "Setting up PostgreSQL and dependencies..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/worktree-deps.sh",
            "timeout": 15,
            "statusMessage": "Provisioning worktree dependencies..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/lsp-warmup.sh",
            "timeout": 10,
            "statusMessage": "Priming LSP warm-up directive..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-recent-issues.sh",
            "timeout": 20
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/inject-patterns.sh",
            "timeout": 10,
            "statusMessage": "Loading patterns for this file..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/inject-patterns.sh",
            "timeout": 10,
            "statusMessage": "Loading patterns for this file..."
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/inject-patterns.sh",
            "timeout": 10,
            "statusMessage": "Loading patterns for this file..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/branch-preflight.sh", "timeout": 10, "statusMessage": "Checking branch before commit..." }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/core-bare-guard.sh", "timeout": 10, "statusMessage": "Checking core.bare integrity..." }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/drift-detect.sh", "timeout": 10, "statusMessage": "Checking for external HEAD drift..." }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/guard-concurrent-session.sh", "timeout": 10, "statusMessage": "Checking for concurrent sessions in this checkout..." }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/batch-size-guard.sh", "timeout": 10, "statusMessage": "" }]
      },
      { "matcher": "Bash", "hooks": [{ "type": "command", "command": "bash .claude/hooks/pr-preflight-guard.sh", "timeout": 10, "statusMessage": "Checking PR preflight stamp..." }] },
      { "matcher": "mcp__github__create_pull_request", "hooks": [{ "type": "command", "command": "bash .claude/hooks/pr-preflight-guard.sh", "timeout": 10, "statusMessage": "Checking PR preflight stamp..." }] },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-worktree-isolation.sh",
            "timeout": 10,
            "statusMessage": "Checking worktree isolation..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-worktree-isolation.sh",
            "timeout": 10,
            "statusMessage": "Checking worktree isolation..."
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-worktree-isolation.sh",
            "timeout": 10,
            "statusMessage": "Checking worktree isolation..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/worktree-deps.sh",
            "timeout": 15,
            "statusMessage": "Provisioning worktree dependencies..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/lsp-nudge.sh",
            "timeout": 10,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/drift-detect-update.sh", "timeout": 10, "statusMessage": "" }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/commit-verify.sh", "timeout": 10, "statusMessage": "Verifying commit landed..." }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/pr-verify.sh", "timeout": 15, "statusMessage": "Verifying PR state..." }]
      },
      {
        "matcher": "mcp__github__create_pull_request",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/pr-verify.sh", "timeout": 15, "statusMessage": "Verifying PR state..." }]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/eslint-fix.sh",
            "timeout": 60,
            "statusMessage": "eslint --fix on changed file..."
          }
        ]
      }
    ]
  }
}
