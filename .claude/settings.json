{
  "enabledPlugins": {},
  "permissions": {
    "allow": [
      "Bash(npx vitest run *)",
      "Bash(npx eslint *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 600,
            "statusMessage": "Setting up PostgreSQL and dependencies..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/worktree-deps.sh",
            "timeout": 15,
            "statusMessage": "Provisioning worktree dependencies..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/inject-patterns.sh",
            "timeout": 10,
            "statusMessage": "Loading patterns for this file..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/inject-patterns.sh",
            "timeout": 10,
            "statusMessage": "Loading patterns for this file..."
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/inject-patterns.sh",
            "timeout": 10,
            "statusMessage": "Loading patterns for this file..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/kimi-review.sh",
            "timeout": 180,
            "statusMessage": "Running kimi-review on staged changes..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-worktree-isolation.sh",
            "timeout": 10,
            "statusMessage": "Checking worktree isolation..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-worktree-isolation.sh",
            "timeout": 10,
            "statusMessage": "Checking worktree isolation..."
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-worktree-isolation.sh",
            "timeout": 10,
            "statusMessage": "Checking worktree isolation..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/worktree-deps.sh",
            "timeout": 15,
            "statusMessage": "Provisioning worktree dependencies..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -s /tmp/ocrecipes-deferred.txt ] && python3 -c \"import json; items=open('/tmp/ocrecipes-deferred.txt').read().strip(); print(json.dumps({'systemMessage': 'Deferred items not yet tracked as todos:\\n' + items + '\\n\\nAsk Claude to create todos for them in todos/'}))\" 2>/dev/null || true",
            "statusMessage": "Checking for untracked deferred items..."
          }
        ]
      }
    ]
  }
}
