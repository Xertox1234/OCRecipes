{
  "enabledPlugins": {},
  "permissions": {
    "allow": [
      "Bash(npx vitest run *)",
      "Bash(npx eslint *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 600,
            "statusMessage": "Setting up PostgreSQL and dependencies..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/worktree-deps.sh",
            "timeout": 15,
            "statusMessage": "Provisioning worktree dependencies..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/lsp-warmup.sh",
            "timeout": 10,
            "statusMessage": "Priming LSP warm-up directive..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/inject-patterns.sh",
            "timeout": 10,
            "statusMessage": "Loading patterns for this file..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/inject-patterns.sh",
            "timeout": 10,
            "statusMessage": "Loading patterns for this file..."
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/inject-patterns.sh",
            "timeout": 10,
            "statusMessage": "Loading patterns for this file..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/kimi-review.sh",
            "timeout": 180,
            "statusMessage": "Running kimi-review on staged changes..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-worktree-isolation.sh",
            "timeout": 10,
            "statusMessage": "Checking worktree isolation..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-worktree-isolation.sh",
            "timeout": 10,
            "statusMessage": "Checking worktree isolation..."
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-worktree-isolation.sh",
            "timeout": 10,
            "statusMessage": "Checking worktree isolation..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/worktree-deps.sh",
            "timeout": 15,
            "statusMessage": "Provisioning worktree dependencies..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/lsp-nudge.sh",
            "timeout": 10,
            "statusMessage": ""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(jq -r '.tool_input.file_path // empty'); case \"$file\" in *.ts|*.tsx|*.js|*.jsx|*.cjs|*.mjs) ESLINT_NO_TYPE_AWARE=1 npx eslint --no-warn-ignored --fix \"$file\" ;; esac",
            "timeout": 60,
            "statusMessage": "eslint --fix on changed file..."
          }
        ]
      }
    ]
  }
}
