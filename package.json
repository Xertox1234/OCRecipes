{
  "name": "ocrecipes",
  "main": "client/index.js",
  "version": "1.0.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "expo:dev": "npx expo start --tunnel",
    "server:dev": "NODE_ENV=development tsx server/index.ts",
    "expo:start:static:build": "npx expo start --no-dev --minify",
    "expo:static:build": "node scripts/build.js",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=server_dist --alias:@shared=./shared",
    "server:prod": "NODE_ENV=production node server_dist/index.js",
    "predb:push": "tsx scripts/check-timestamptz-migration.ts",
    "db:push": "drizzle-kit push",
    "lint": "ESLINT_NO_TYPE_AWARE= npx expo lint",
    "lint:fix": "npx expo lint --fix",
    "lint:suppress": "ESLINT_NO_TYPE_AWARE= eslint . --suppress-rule @typescript-eslint/no-floating-promises --suppress-rule @typescript-eslint/no-misused-promises --suppress-rule @typescript-eslint/await-thenable --suppress-rule @typescript-eslint/require-await --suppress-rule @typescript-eslint/no-implied-eval --suppress-rule @typescript-eslint/prefer-promise-reject-errors",
    "lint:suppress:prune": "ESLINT_NO_TYPE_AWARE= eslint . --prune-suppressions",
    "lint:suppress:check": "ESLINT_NO_TYPE_AWARE= eslint . --prune-suppressions && git diff --exit-code -- eslint-suppressions.json",
    "lint:a11y": "node scripts/check-accessibility.js",
    "check:types": "tsc --noEmit",
    "check:types:incremental": "mkdir -p node_modules/.cache && tsc --noEmit --incremental --tsBuildInfoFile node_modules/.cache/tsc-precommit.tsbuildinfo",
    "ci:failed-logs": "bash scripts/ci-failed-logs.sh",
    "copilot:delegate:dry-run": "tsx scripts/delegate-copilot-issue.ts --dry-run",
    "copilot:delegate": "tsx scripts/delegate-copilot-issue.ts --live",
    "build:copilot-instructions": "tsx scripts/build-copilot-instructions.ts .github/copilot-instructions.md",
    "build:copilot-instructions:check": "tsx scripts/build-copilot-instructions.ts --check .github/copilot-instructions.md",
    "build:domain-map": "tsx scripts/build-domain-map.ts .claude/hooks/lib/domain-map.sh",
    "build:domain-map:check": "tsx scripts/build-domain-map.ts --check .claude/hooks/lib/domain-map.sh",
    "build:generated:check": "npm run build:copilot-instructions:check && npm run build:domain-map:check",
    "check:format": "prettier --check \"**/*.{js,ts,tsx,css,json}\"",
    "format": "prettier --write \"**/*.{js,ts,tsx,css,json}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run --exclude 'server/storage/__tests__/**'",
    "test:integration": "vitest run server/storage/__tests__/",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ci": "vitest run --coverage --coverage.thresholds.autoUpdate=false",
    "coverage:ratchet": "tsx scripts/coverage-ratchet.ts",
    "test:mutation": "stryker run",
    "mutation:explore": "node scripts/mutation-explore.mjs",
    "prepare": "husky",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "seed:recipes": "tsx server/scripts/seed-recipes.ts",
    "solutions:db:init": "psql \"$SOLUTIONS_DATABASE_URL\" -v ON_ERROR_STOP=1 -f scripts/solutions-db/schema.sql",
    "solutions:db:add": "tsx scripts/solutions-db/add.ts",
    "solutions:db:ingest": "tsx scripts/solutions-db/ingest.ts",
    "solutions:db:dedup": "tsx scripts/solutions-db/dedup-report.ts",
    "solutions:db:check": "tsx scripts/solutions-db/integration-check.ts",
    "solutions:db:parity": "tsx scripts/solutions-db/parity-check.ts",
    "solutions:db:export": "tsx scripts/solutions-db/export.ts",
    "solutions:db:hook-check": "tsx scripts/solutions-db/hook-equivalence-check.ts",
    "solutions:db:recent": "tsx scripts/solutions-db/recent.ts",
    "cleanup:seeds": "tsx server/scripts/cleanup-seed-recipes.ts",
    "cleanup:retention": "tsx server/scripts/cleanup-retention.ts",
    "migrate:images-r2": "tsx server/scripts/migrate-images-to-r2.ts",
    "backfill:community-nutrition": "tsx server/scripts/backfill-community-nutrition.ts",
    "backfill:email-verified": "tsx server/scripts/backfill-email-verified.ts",
    "e2e": "maestro test e2e/flows/",
    "e2e:smoke": "maestro test --tags smoke e2e/flows/",
    "eval:coach": "npx tsx evals/runner.ts",
    "eval:recipe-chat": "npx tsx evals/runner-recipe-chat.ts",
    "eval:meal-suggestions": "npx tsx evals/runner-meal-suggestions.ts",
    "eval:recipe-generation": "EVAL_SKIP_IMAGE_GENERATION=true npx tsx evals/runner-recipe-generation.ts",
    "eval:photo": "npx tsx evals/runner-photo-analysis.ts",
    "eval:all": "npm run eval:coach && npm run eval:recipe-chat && npm run eval:meal-suggestions && npm run eval:recipe-generation",
    "generate:icons": "npx tsx scripts/generate-ingredient-icons.ts",
    "lsp:check-agent-block": "bash scripts/check-lsp-agent-block.sh",
    "preflight": "bash scripts/preflight.sh",
    "preflight:fast": "bash scripts/preflight.sh --fast"
  },
  "dependencies": {
    "@apple/app-store-server-library": "^2.0.0",
    "@aws-sdk/client-s3": "^3.1063.0",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-community/slider": "^5.2.0",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@sentry/react-native": "~7.2.0",
    "@tanstack/query-async-storage-persister": "^5.101.0",
    "@tanstack/react-query": "^5.90.7",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.1",
    "expo": "^54.0.23",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.9",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.9",
    "expo-glass-effect": "~0.1.10",
    "expo-haptics": "~15.0.8",
    "expo-iap": "^3.4.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.8",
    "expo-modules-core": "^3.0.29",
    "expo-notifications": "^55.0.14",
    "expo-server-sdk": "^6.1.0",
    "expo-speech": "~14.0.8",
    "expo-speech-recognition": "^3.1.1",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "express": "^5.0.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "minisearch": "^7.2.0",
    "multer": "^2.2.0",
    "node-cron": "^4.2.1",
    "openai": "^6.39.0",
    "p-limit": "^7.3.0",
    "p-retry": "^7.1.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-nitro-image": "^0.14.0",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.1",
    "react-native-vision-camera": "^5.0.11",
    "react-native-vision-camera-barcode-scanner": "^5.0.11",
    "react-native-worklets": "~0.8.3",
    "resend": "^6.14.0",
    "tsx": "^4.22.3",
    "zod": "^3.25.76",
    "zod-validation-error": "^3.5.4"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@expo/ngrok": "^4.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "24.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "~19.1.0",
    "@types/react-dom": "^19.1.11",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.7",
    "babel-plugin-module-resolver": "^5.0.3",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-plugin-prettier": "^5.5.5",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.6",
    "pino-pretty": "^13.1.3",
    "prettier": "3.6.2",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.5",
    "supertest": "^7.2.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "form-data": "^4.0.6",
    "postcss": "^8.5.10",
    "qs": "^6.15.2",
    "undici": "^7.28.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "env ESLINT_NO_TYPE_AWARE=1 eslint --fix",
      "prettier --write"
    ],
    "client/**/*.tsx": [
      "node scripts/check-accessibility.js",
      "node scripts/check-hardcoded-colors.js"
    ],
    "client/components/**/__tests__/*.test.tsx": [
      "node scripts/check-jsdom-pragma.js"
    ],
    "server/storage/*.ts": [
      "node scripts/check-idor-storage.js"
    ],
    "evals/datasets/*.json": [
      "node scripts/check-eval-dataset-secrets.js"
    ],
    "*.{js,md}": [
      "prettier --write"
    ]
  },
  "private": true
}
